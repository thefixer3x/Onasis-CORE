# Live integration test environment for auth-gateway.
# Copy to .env.test and fill in real test-only values, OR encrypt with:
#   dotenvx encrypt -f .env.test
#
# Used by the test:integration:live npm script:
#   dotenvx run --strict --ops-off -f .env.test -- \
#     RUN_AUTH_GATEWAY_INTEGRATION=true vitest run tests/integration

# Mode
NODE_ENV=test
PORT=3001

# Required by config/env.js Zod schema
JWT_SECRET=test-jwt-secret-fixed-32-bytes-min-len!

# Test Postgres (must be a non-prod DB you can write to)
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB
DIRECT_DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB

# Test Supabase project (separate from prod)
SUPABASE_URL=https://YOUR-TEST-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_TEST_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_TEST_SERVICE_ROLE_KEY

# Optional
AUTH_BASE_URL=https://auth.lanonasis.com
COOKIE_DOMAIN=.lanonasis.test
DASHBOARD_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=warn
LOG_FORMAT=json

# Gate — leave OFF here; the npm script flips it on for the live suite
# RUN_AUTH_GATEWAY_INTEGRATION=true
