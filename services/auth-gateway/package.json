{
  "name": "auth-gateway",
  "version": "0.2.0",
  "description": "Supabase-integrated authentication gateway for Lan-Onasis platform",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p .",
    "start": "dotenvx run --strict --ops-off -f .env.production -- node start.js",
    "start:plain": "node start.js",
    "start:pm2": "pm2-runtime start ecosystem.config.cjs",
    "db:migrate": "node run-migration.mjs",
    "db:migrate:status": "node run-migration.mjs --status",
    "db:migrate:baseline-existing": "node run-migration.mjs --baseline-existing",
    "db:migrate:prod": "dotenvx run --ops-off -f .env.production -- node run-migration.mjs",
    "db:migrate:status:prod": "dotenvx run --ops-off -f .env.production -- node run-migration.mjs --status",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit --reporter=verbose",
    "test:ci": "vitest run tests/unit/auth.test.ts tests/unit/body-validation.test.ts tests/unit/csrf.test.ts tests/unit/pkce.test.ts --reporter=verbose",
    "test:integration": "vitest run tests/integration --reporter=verbose",
    "test:integration:live": "dotenvx run --strict --ops-off -f .env.test -- cross-env RUN_AUTH_GATEWAY_INTEGRATION=true vitest run tests/integration/auth-introspect.smoke --reporter=verbose",
    "test:security": "vitest run tests/security --reporter=verbose --passWithNoTests",
    "test:load": "k6 run tests/load/oauth-flow.js",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "outbox:forward": "tsx src/workers/outbox-forwarder.ts",
    "bootstrap:supabase": "tsx scripts/bootstrap-from-supabase.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@supabase/supabase-js": "^2.104.1",
    "bun": "^1.3.13",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "flatted": "^3.4.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1",
    "ms": "^2.1.3",
    "node-fetch": "^3.3.2",
    "path-to-regexp": "^8.4.2",
    "pg": "^8.20.0",
    "picomatch": "^4.0.4",
    "prom-client": "^15.1.3",
    "qs": "6.15.0",
    "redis": "^5.12.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.63.0",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "k6": "^0.0.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "body-parser": "^2.2.1",
    "js-yaml": "^4.1.1",
    "ajv": "^8.17.1",
    "qs": "6.15.0",
    "diff": "^8.0.3",
    "minimatch": "^10.2.1",
    "rollup": "^4.59.0",
    "brace-expansion": "^2.0.2",
    "postcss": "^8.5.10",
    "path-to-regexp": "^8.4.2",
    "picomatch": "^4.0.4",
    "flatted": "^3.4.2",
    "fast-uri": ">=3.1.2"
  }
}
